{
  "$ref": "#/definitions/PanelConfig",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "LayoutConfig": {
      "additionalProperties": false,
      "properties": {
        "classBackground": {
          "type": "string"
        },
        "classGrid": {
          "type": "string"
        },
        "columns": {
          "type": "number"
        },
        "gap": {
          "type": "number"
        },
        "rows": {
          "type": "number"
        },
        "styleBackground": {
          "$ref": "#/definitions/Style"
        },
        "styleGrid": {
          "$ref": "#/definitions/Style"
        }
      },
      "required": [
        "columns",
        "rows"
      ],
      "type": "object"
    },
    "PanelConfig": {
      "additionalProperties": false,
      "properties": {
        "layout": {
          "$ref": "#/definitions/LayoutConfig"
        },
        "version": {
          "type": "string"
        },
        "widgets": {
          "additionalProperties": {
            "$ref": "#/definitions/WidgetConfig"
          },
          "type": "object"
        }
      },
      "required": [
        "version",
        "layout",
        "widgets"
      ],
      "type": "object"
    },
    "Style": {
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      },
      "properties": {},
      "type": "object"
    },
    "WebSocketConfig": {
      "additionalProperties": false,
      "properties": {
        "topic": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "topic"
      ],
      "type": "object"
    },
    "WidgetConfig": {
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "string"
        },
        "position": {
          "$ref": "#/definitions/WidgetPosition"
        },
        "props": {
          "properties": {
            "dataSource": {
              "anyOf": [
                {
                  "$ref": "#/definitions/WebSocketConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "widgetSource": {
              "anyOf": [
                {
                  "$ref": "#/definitions/WebSocketConfig"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "dataSource",
            "widgetSource"
          ],
          "type": "object"
        },
        "style": {
          "$ref": "#/definitions/Style"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "position",
        "props"
      ],
      "type": "object"
    },
    "WidgetPosition": {
      "additionalProperties": false,
      "properties": {
        "h": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "w",
        "h"
      ],
      "type": "object"
    }
  }
}

